# ── LLM ──────────────────────────────────────────────
# Removed: ANTHROPIC_API_KEY (no longer needed)

# ── Redis ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Agent behaviour ─────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
MAX_RETRIES=3
RETRY_BASE_MS=800
MAX_REVISIONS=2

# ── Output ───────────────────────────────────────────
OUTPUT_DIR=./output

# ── Store TTL (seconds) ─────────────────────────────
STORE_TTL_SECONDS=86400

# ── RetrieverAgent — SerpAPI ───────────────────────────
# Get your key at: https://serpapi.com/
# Budget cap: ≤50 calls/month enforced via cache-first strategy.
# Leave empty to run in LLM-fallback mode (no real retrieval).
SERPAPI_KEY=# ADD_YOUR_SERPAPI_KEY
# Number of context chunks to keep after filtering (default: 5)
RETRIEVER_MAX_CHUNKS=5
